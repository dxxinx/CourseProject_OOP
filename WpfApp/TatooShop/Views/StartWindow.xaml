<Window x:Class="TatooShop.Views.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        Title="Главная — Ink&amp;Skin" Icon="/image/logo.ico" Height="840" Width="1360" MinHeight="840" MinWidth="1360" WindowState="Maximized">
    <Window.DataContext>
        <vm:StartViewModel/>
    </Window.DataContext>
    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Меню навигации -->
        <Border Grid.Row="0" Margin="40 30 40 0" Padding="20 15"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/image/logo48x48.png" Width="30" Height="30" Margin="0 0 15 0"/>
                    <TextBlock Text="Tattoo Studio" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Menu Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <MenuItem Header="Каталог эскизов" Command="{Binding SketchCommand}" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Наши мастера" Command="{Binding MasterCommand}" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Избранное" Click="Favorite_Window_Click" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Личный кабинет" Click="Personal_Window_Click" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Выйти" Click="Logout_Click" Style="{StaticResource MenuClick}" Foreground="#FF6B6B"/>
                </Menu>
            </DockPanel>
        </Border>
        <!-- Главный контент -->
        <Grid Grid.Row="1" Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Margin="0 0 70 0">
                <TextBlock Text="Твоя кожа. Твоя история. Твой выбор."
                           Foreground="White"
                           FontSize="56"
                           FontWeight="ExtraBold"
                           TextWrapping="Wrap"
                           LineHeight="64"/>
                <TextBlock Text="Мы создаем искусство: лучшие тату мастера, сотни эскизов и индивидуальный подход к каждому клиенту в нашей студии."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="18"
                           TextWrapping="Wrap"
                           Margin="0 25 0 40"
                           LineHeight="26"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Записаться на сеанс" Click="Reservation_Window_Click" Width="216" Height="50" FontSize="15"/>
                    <Button Content="Смотреть эскизы"
                            Command="{Binding SketchCommand}"
                            Width="216"
                            Height="50"
                            Margin="35 0 0 0"
                            Background="Transparent"
                            Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"/>
                </StackPanel>
            </StackPanel>
            <!-- Блок с изображениями -->
            <Border Grid.Column="1"
                    Width="560"
                    HorizontalAlignment="Right"
                    CornerRadius="12"
                    ClipToBounds="True"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.Background>
                        <ImageBrush ImageSource="/image/fon2.png"
                                    Stretch="UniformToFill"
                                    AlignmentX="Center"
                                    AlignmentY="Center"/>
                    </Grid.Background>
                    <Border Background="#50000000"/>
                    <Border VerticalAlignment="Bottom" Padding="30" Background="#E6100A18">
                        <StackPanel>
                            <TextBlock Text="Высшее качество" Foreground="White" FontSize="26" FontWeight="Bold"/>
                            <TextBlock Text="Стерильные условия и премиум краски для вашей безопасности."
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0 10 0 0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- Подвал -->
        <Border Grid.Row="2" Margin="40 0 40 40" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="25">
            <DockPanel>
                <TextBlock Text="Скидка 10%" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left" Margin="0 0 25 0" VerticalAlignment="Center"/>
                <TextBlock Text="Приведи друга, запишись сам и получите оба скидку при первом посещении нашей студии."
                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
