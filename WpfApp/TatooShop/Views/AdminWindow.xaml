<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="TatooShop.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        mc:Ignorable="d"
        Title="Панель администратора — Ink&amp;Skin"
        Height="900"
        Width="1500"
        MinHeight="900"
        MinWidth="1500"
        Background="Black"
        WindowState="Maximized">
    <Window.DataContext>
        <vm:AdminViewModel/>
    </Window.DataContext>

    <Window.Icon>
        <ImageSource>/image/logo.ico</ImageSource>
    </Window.Icon>

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#050505"/>
        <SolidColorBrush x:Key="CardBrush" Color="#CC0B0B0B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#4A2A67"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#B14DFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="White"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#C7B7D7"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#24122F"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#7A2230"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#94283A"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#150A1D"/>
        <SolidColorBrush x:Key="GridRowBrush" Color="#0B0B0B"/>
        <SolidColorBrush x:Key="GridAlternateBrush" Color="#111111"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#5A2C84"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0 0 0 18"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#0D0912"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionTextBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#4C4C4C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="Background" Value="#111111"/>
                        <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="10 6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2C133F"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1E0D2A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="12 0 8 0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      RecognizesAccessKey="True"/>

                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <TextBlock Text="▼"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#111111"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="260"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="16 9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CA82FF"/>
                                <Setter Property="Foreground" Value="#09030D"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#CA82FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8E35D8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#8E35D8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="140"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#5F1A26"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#5F1A26"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="Padding" Value="18 10"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#353535"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14 14 0 0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#140A1B"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource GridRowBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAlternateBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
            <Setter Property="Padding" Value="12 10"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0 0 1 1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12 10"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0 0 1 1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="/Fonts/#M PLUS 1p"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#CC000000"/>

        <Border Grid.Row="0"
                Margin="20 20 20 12"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Панель администратора"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="/Fonts/#M PLUS 1p"/>
                    <TextBlock Text="Управление сотрудниками, эскизами, записями и обращениями."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0 6 0 0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Выйти"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"
                        Click="Logout_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    x:Name="AdminTabControl"
                    Margin="20 0 20 20"
                    SelectionChanged="AdminTabControl_SelectionChanged">
            <TabItem Header="Администраторы">
                <Border Margin="0"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="500"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Grid.Column="0"
                                 Margin="0 0 16 16"
                                 Text="{Binding AdminQuery, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGrid Grid.Row="1"
                                  Grid.Column="0"
                                  Margin="0 0 16 0"
                                  ItemsSource="{Binding AdminDataGrid}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="60"/>
                                <DataGridTextColumn Binding="{Binding FullName}" Header="ФИО" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" Width="150"/>
                                <DataGridTextColumn Binding="{Binding EMail}" Header="Email" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Phone}" Header="Телефон" Width="150"/>
                                <DataGridTemplateColumn Header="Действие" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource DeleteAdminCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Background="#B30A0A0A">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Добавить администратора"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Короткая форма для создания нового аккаунта."
                                               Style="{StaticResource SectionDescriptionStyle}"/>

                                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminSurname, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminMiddleName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Логин" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminLogin, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminEmail, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AdminPhone, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Button Command="{Binding SaveAdminCommand}"
                                            Margin="0 6 0 0"
                                            Content="Создать администратора"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Пользователи">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Margin="0 0 0 16"
                                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding UserDataGrid}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="60"/>
                                <DataGridTextColumn Binding="{Binding FullName}" Header="ФИО" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Login}" Header="Логин" Width="160"/>
                                <DataGridTextColumn Binding="{Binding EMail}" Header="Email" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Phone}" Header="Телефон" Width="160"/>
                                <DataGridTextColumn Binding="{Binding Address}" Header="Адрес" Width="240"/>
                                <DataGridTemplateColumn Header="Действие" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource DeleteUserCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Эскизы">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0 0 0 16">
                            <ComboBox Width="180"
                                      Margin="0 0 12 0"
                                      ItemsSource="{Binding TatooTypesFilterList}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding FilterType}"/>
                            <ComboBox Width="190"
                                      Margin="0 0 12 0"
                                      ItemsSource="{Binding PlacementFilterList}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding FilterPlacement}"/>
                            <ComboBox Width="170"
                                      Margin="0 0 12 0"
                                      ItemsSource="{Binding SizeFilterList}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding FilterSize}"/>
                            <ComboBox Width="170"
                                      Margin="0 0 12 0"
                                      ItemsSource="{Binding TimeFilterList}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding FilterTime}"/>
                            <ComboBox Width="190"
                                      Margin="0"
                                      ItemsSource="{Binding ComplexityFilterList}"
                                      DisplayMemberPath="Title"
                                      SelectedItem="{Binding FilterComplexity}"/>
                        </WrapPanel>

                        <DataGrid Grid.Row="1"
                                  Grid.Column="0"
                                  Margin="0 0 16 0"
                                  ItemsSource="{Binding SketchDataGrid}"
                                  SelectedItem="{Binding SelectedSketch}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="44"/>
                                <DataGridTextColumn Binding="{Binding StyleLabel}" Header="Стиль" Width="1.05*"/>
                                <DataGridTextColumn Binding="{Binding Master.FullName}" Header="Мастер" Width="1.45*"/>
                                <DataGridTextColumn Binding="{Binding PlacementLabel}" Header="Место" Width="0.9*"/>
                                <DataGridTextColumn Binding="{Binding SizeLabel}" Header="Размер" Width="0.78*"/>
                                <DataGridTextColumn Binding="{Binding EstimatedTimeLabel}" Header="Время" Width="74"/>
                                <DataGridTextColumn Binding="{Binding ComplexityLabel}" Header="Сложн." Width="0.85*"/>
                                <DataGridTemplateColumn Header="" Width="94">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource DeleteSketchCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Background="#B30A0A0A">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding SketchFormTitle}"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Загрузите изображение, выберите стиль и мастера."
                                           Style="{StaticResource SectionDescriptionStyle}"/>

                                <TextBlock Text="Стиль" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding TatooTypesList}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding Type}"/>

                                <TextBlock Text="Мастер" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding SketchMasterList}"
                                          DisplayMemberPath="FullName"
                                          SelectedItem="{Binding SelectedSketchMaster}"/>

                                <TextBlock Text="Локализация" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding PlacementList}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding Placement}"/>

                                <TextBlock Text="Размер" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding SizeList}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding Size}"/>

                                <TextBlock Text="Примерное время выполнения, ч" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding EstimatedHours, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Сложность" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding ComplexityList}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding Complexity}"/>

                                <TextBlock Text="Изображение" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Height="190"
                                        Margin="0 0 0 14"
                                        CornerRadius="14"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        Background="#111111">
                                    <Image Source="{Binding Image}" Stretch="Uniform"/>
                                </Border>

                                <Button Command="{Binding ImageCommand}"
                                        Margin="0 0 0 10"
                                        Content="Загрузить изображение"/>
                                <Button Command="{Binding SaveCommand}"
                                        Margin="0 0 0 10"
                                        Content="{Binding SketchSaveButtonText}"/>
                                <Button Command="{Binding ClearSketchFormCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Width="180"
                                        Content="Новый эскиз"/>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Мастера">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="540"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Grid.Column="0"
                                 Margin="0 0 16 16"
                                 Text="{Binding MasterSearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGrid Grid.Row="1"
                                  Grid.Column="0"
                                  Margin="0 0 16 0"
                                  ItemsSource="{Binding MasterDataGrid}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="60"/>
                                <DataGridTextColumn Binding="{Binding FullName}" Header="ФИО" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Specialization}" Header="Специализация" Width="180"/>
                                <DataGridTextColumn Binding="{Binding Experience}" Header="Стаж" Width="120"/>
                                <DataGridTemplateColumn Header="Действие" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource DeleteMasterCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Background="#B30A0A0A">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Добавить мастера"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Карточка мастера с фото, стажем и специализацией."
                                               Style="{StaticResource SectionDescriptionStyle}"/>

                                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Специализация" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding TatooTypesList}"
                                              DisplayMemberPath="Title"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding TypeMaster}"/>

                                    <TextBlock Text="Стаж" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Experience, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Фотография" Style="{StaticResource FieldLabelStyle}"/>
                                    <Border Height="190"
                                            Margin="0 0 0 14"
                                            CornerRadius="14"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                        Background="#111111">
                                        <Image Source="{Binding ImageMaster}" Stretch="Uniform"/>
                                    </Border>

                                    <Button Command="{Binding ImageMasterCommand}"
                                            Margin="0 0 0 10"
                                            Content="Загрузить изображение"/>
                                    <Button Command="{Binding SaveMasterCommand}"
                                            Content="Сохранить мастера"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Сеансы">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding ReservationDataGrid}"
                                  SelectedItem="{Binding SelectedReservation}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="60"/>
                                <DataGridTextColumn Binding="{Binding User.FullName}" Header="Клиент" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Master.FullName}" Header="Мастер" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Header="Дата" Width="140"/>
                                <DataGridTextColumn Binding="{Binding Time}" Header="Время" Width="120"/>
                                <DataGridTextColumn Binding="{Binding StatusText}" Header="Статус" Width="180"/>
                                <DataGridTemplateColumn Header="Напоминание" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource ReminderCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Width="130"
                                                    Content="Напомнить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Отмена" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{StaticResource CancelReservationCommand}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Content="Отменить"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="1"
                                Margin="0 16 0 0"
                                HorizontalAlignment="Left"
                                Command="{Binding ConfirmReservationCommand}"
                                Content="Подтвердить выбранную запись"/>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Техподдержка">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  Margin="0 0 16 0"
                                  ItemsSource="{Binding SupportRequestDataGrid}"
                                  SelectedItem="{Binding SelectedSupportRequest}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="DataGrid_SelectionChanged_1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="50"/>
                                <DataGridTemplateColumn Header="Пользователь" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding User.FullName}" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Тема" Width="1.1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Subject}" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Сообщение" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Header="Создано" Width="125"/>
                                <DataGridTextColumn Binding="{Binding IsProcessed}" Header="Обработано" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Background="#B30A0A0A">
                            <StackPanel MinWidth="300">
                                <TextBlock Text="Ответ админа"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Выберите обращение слева и отправьте ответ."
                                           Style="{StaticResource SectionDescriptionStyle}"/>

                                <TextBlock Text="{Binding SelectedSupportRequest.Subject}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0 0 0 8"/>
                                <TextBlock Text="{Binding SelectedSupportRequest.Message}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0 0 0 12"/>

                                <TextBox Height="160"
                                          TextWrapping="Wrap"
                                          AcceptsReturn="True"
                                          Padding="14 8"
                                          VerticalContentAlignment="Top"
                                          VerticalScrollBarVisibility="Auto"
                                          IsEnabled="{Binding CanReplySupportRequest}"
                                          Text="{Binding SupportReply, UpdateSourceTrigger=PropertyChanged}"/>

                                <Button Margin="0 4 0 0"
                                        Command="{Binding ProcessSupportRequestCommand}"
                                        IsEnabled="{Binding CanReplySupportRequest}"
                                        Content="Отправить ответ"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
