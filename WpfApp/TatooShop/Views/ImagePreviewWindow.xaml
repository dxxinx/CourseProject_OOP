<Window x:Class="TatooShop.Views.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр изображения — Ink&amp;Skin"
        Icon="/image/logo.ico"
        Width="960"
        Height="740"
        MinWidth="960"
        MinHeight="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#050505"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PreviewTitle"
                   Foreground="White"
                   FontSize="20"
                   FontFamily="/Fonts/#M PLUS 1p"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   LineHeight="26"
                   MaxHeight="56"
                   Margin="0 0 0 14"/>

        <Border Grid.Row="1"
                Background="#111111"
                BorderBrush="#B14DFF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>

        <Button Grid.Row="2"
                Width="180"
                Margin="0 18 0 0"
                HorizontalAlignment="Right"
                Click="Close_Click"
                Content="Закрыть"/>
    </Grid>
</Window>


