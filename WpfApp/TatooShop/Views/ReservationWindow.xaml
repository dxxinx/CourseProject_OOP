<Window x:Class="TatooShop.Views.ReservationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        Title="Запись на сеанс - Ink&amp;Skin"
        Icon="/image/logo.ico"
        Width="1020"
        Height="660"
        MinWidth="1020"
        MinHeight="660"
        MaxWidth="1020"
        MaxHeight="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:ReservationViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="BookingCalendarDayButtonStyle" TargetType="{x:Type primitives:CalendarDayButton}">
            <Setter Property="Background" Value="#0D0912"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#241331"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#665C70"/>
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="Foreground" Value="#514A5C"/>
                                <Setter TargetName="DayBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BookingCalendarButtonStyle" TargetType="{x:Type primitives:CalendarButton}">
            <Setter Property="Background" Value="#0D0912"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="BookingCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="#0D0912"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource BookingCalendarDayButtonStyle}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource BookingCalendarButtonStyle}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource CanvasBrush}">
        <Border Background="{StaticResource PanelBrush}"
                Margin="30"
                CornerRadius="12"
                Padding="28"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#0D0912"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Text="Выберите дату"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0 0 0 16"/>

                        <Border Background="#111111"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="18 14"
                                Margin="0 0 0 16">
                            <StackPanel>
                                <TextBlock Text="{Binding UserDate, StringFormat={}{0:yyyy}}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="16"/>
                                <TextBlock Text="{Binding UserDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Calendar Width="366"
                                  Height="300"
                                  HorizontalAlignment="Left"
                                  SelectedDate="{Binding UserDate, Mode=TwoWay}"
                                  DisplayDate="{Binding UserDate}"
                                  FirstDayOfWeek="Monday"
                                  Style="{StaticResource BookingCalendarStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Запись"
                               FontSize="32"
                               FontWeight="Bold"
                               Margin="0 0 0 28"/>

                    <TextBlock Text="Мастер"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0 0 0 7"/>
                    <ComboBox ItemsSource="{Binding MastersList}"
                              SelectedItem="{Binding Master}"
                              DisplayMemberPath="FullName"
                              Height="42"
                              Margin="0 0 0 18"/>

                    <TextBlock Text="Дата"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0 0 0 7"/>
                    <Border Height="42"
                            Background="#0D0912"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            Margin="0 0 0 18">
                        <TextBlock Text="{Binding UserDate, StringFormat={}{0:dd.MM.yyyy}}"
                                   Foreground="White"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="14 0"/>
                    </Border>

                    <TextBlock Text="Время"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0 0 0 7"/>
                    <ComboBox ItemsSource="{Binding AvailableTimeList}"
                              SelectedItem="{Binding SelectedTime}"
                              Height="42"
                              Margin="0 0 0 26"/>

                    <Button Content="Забронировать"
                            Height="48"
                            Command="{Binding ReservationCommand}"/>
                    <Button Content="Отмена"
                            Height="48"
                            Background="Transparent"
                            Foreground="{StaticResource MutedBrush}"
                            Margin="0 12 0 0"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
