<Window x:Class="TatooShop.Views.FavoriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        Title="Избранное — Ink&amp;Skin" Icon="/image/logo.ico" Height="760" Width="1160" MinHeight="760" MinWidth="1160" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:FavoriteViewModel/>
    </Window.DataContext>
    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="30 30 30 0" Padding="25" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Сохраненные эскизы" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Здесь хранятся работы, которые вам понравились" Foreground="{StaticResource MutedBrush}" Margin="0 5 0 0"/>
                </StackPanel>
                <TextBlock Text="Удалить эскиз можно по крестику на карточке"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding UserFavorite}"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="20 20 20 20"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="280" Margin="15" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="280"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Image Source="{Binding Sketch.ImageSource}" Stretch="UniformToFill"/>
                            <Button x:Name="DeleteButton"
                                    CommandParameter="{Binding}"
                                    Command="{StaticResource DeleteFavoriteCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="15"
                                    Width="40"
                                    Height="40"
                                    Visibility="Hidden"
                                    Background="#E6110B18"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                <Viewbox Width="14"
                                         Height="14"
                                         Stretch="Uniform">
                                    <Path Stroke="White"
                                          StrokeThickness="2.4"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M1,1 L11,11 M11,1 L1,11"/>
                                </Viewbox>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="20" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Border Grid.Row="1" Padding="15" Background="#F2110B18">
                                <StackPanel>
                                    <TextBlock Text="Идея для тату" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Сохранено из каталога" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0 4 0 0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
