<Window x:Class="TatooShop.Views.SketchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        Title="Каталог эскизов - Ink&amp;Skin" Icon="/image/logo.ico" Height="860" Width="1320" MinHeight="860" MinWidth="1320" WindowState="Maximized">
    <Window.DataContext>
        <vm:SketchViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="EmptySketchStateStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SketchGridStyle" TargetType="ItemsControl">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="23*"/>
            <ColumnDefinition Width="637*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="40,30,40,289" Padding="20 14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="12" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Image Source="/image/logo48x48.png" Width="30" Height="30" Margin="0 0 14 0"/>
                    <StackPanel>
                        <TextBlock Text="Ink&amp;Skin" Foreground="White" FontSize="18" FontWeight="ExtraBold"/>
                        <TextBlock Text="каталог эскизов" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Menu Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right">
                    <MenuItem Header="Главная" Command="{Binding StartCommand}" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Каталог эскизов" Style="{StaticResource MenuClick}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0 0 0 2"/>
                    <MenuItem Header="Наши мастера" Command="{Binding MasterCommand}" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Избранное" Click="Favorite_Window_Click" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Личный кабинет" Click="Personal_Window_Click" Style="{StaticResource MenuClick}"/>
                    <MenuItem Header="Выйти" Click="Logout_Click" Style="{StaticResource MenuClick}" Foreground="#FF6B6B"/>
                </Menu>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="40 28 40 24" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="38" FontWeight="ExtraBold">
                        <Run Foreground="White" Text="КАТАЛОГ "/>
                        <Run Foreground="{StaticResource AccentBrush}" Text="ЭСКИЗОВ"/>
                    </TextBlock>
                    <TextBlock Text="Подберите идею по стилю, месту нанесения, сложности и мастеру"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="16"
                               Margin="0 8 0 0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        MinWidth="210"
                        Padding="18 12"
                        Background="#0D0912"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Найдено работ" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding SearchResult.Count}" Foreground="White" FontSize="28" FontWeight="ExtraBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,10,0,-10"
                    Padding="20"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0 0 0 16">
                        <TextBlock Text="Фильтры" Foreground="White" FontSize="20" FontWeight="Bold" DockPanel.Dock="Left"/>
                        <TextBlock Text="настройте подборку эскизов" Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Right"/>
                    </DockPanel>

                    <UniformGrid Grid.Row="1" Columns="6">
                        <StackPanel Margin="0 0 14 0">
                            <TextBlock Text="Стиль" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding TatooTypesList}" SelectedItem="{Binding SelectedTypeFilter}" DisplayMemberPath="Title" Height="40" SelectionChanged="ComboBox_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 14 0">
                            <TextBlock Text="Место" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding PlacementFilterList}" SelectedItem="{Binding SelectedPlacementFilter}" DisplayMemberPath="Title" Height="40"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 14 0">
                            <TextBlock Text="Размер" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding SizeFilterList}" SelectedItem="{Binding SelectedSizeFilter}" DisplayMemberPath="Title" Height="40"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 14 0">
                            <TextBlock Text="Сложность" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ComplexityFilterList}" SelectedItem="{Binding SelectedComplexityFilter}" DisplayMemberPath="Title" Height="40"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 14 0">
                            <TextBlock Text="Время" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding TimeFilterList}" SelectedItem="{Binding SelectedTimeFilter}" DisplayMemberPath="Title" Height="40"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Мастер" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding MasterFilterList}" SelectedItem="{Binding SelectedMasterFilter}" DisplayMemberPath="Title" Height="40"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="40,289,40,30" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Border Style="{StaticResource EmptySketchStateStyle}"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="40">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding EmptyStateMessage}" Foreground="White" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
                    <TextBlock Text="Попробуйте изменить фильтры или выбрать другой стиль."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="16"
                               Margin="0 10 0 0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0 0 12 0">
                <ItemsControl ItemsSource="{Binding SearchResult}" Style="{StaticResource SketchGridStyle}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="330"
                                    MinHeight="470"
                                    Margin="0 0 22 22"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="12"
                                    ClipToBounds="True"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="260"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Image Source="{Binding ImageSource}" Stretch="UniformToFill"/>
                                        <Border Background="#22000000"/>
                                        <Button Command="{StaticResource FavoriteCommand}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="12"
                                                Style="{StaticResource SketchFavoriteButtonStyle}">
                                            <Viewbox Width="20" Height="20"
                                                     Stretch="Uniform">
                                                <Path x:Name="HeartIcon"
                                                      Fill="#08050B"
                                                      Data="M12,21.35 L10.55,20.03 C5.4,15.36 2,12.28 2,8.5 C2,5.42 4.42,3 7.5,3 C9.24,3 10.91,3.81 12,5.08 C13.09,3.81 14.76,3 16.5,3 C19.58,3 22,5.42 22,8.5 C22,12.28 18.6,15.36 13.45,20.04 L12,21.35 Z"/>
                                            </Viewbox>
                                        </Button>
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Margin="14"
                                                Padding="12 7"
                                                Background="#D20D0912"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <TextBlock Text="{Binding StyleLabel}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="18 18 18 20">
                                        <TextBlock Text="{Binding AuthorName}" Foreground="White" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding PlacementLabel, StringFormat='Место: {0}'}" Foreground="{StaticResource MutedBrush}" Margin="0 6 0 0"/>

                                        <UniformGrid Columns="3" Margin="0 18 0 18">
                                            <Border Background="#0D0912" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0 0 8 0">
                                                <StackPanel>
                                                    <TextBlock Text="Размер" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding SizeLabel}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#0D0912" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0 0 8 0">
                                                <StackPanel>
                                                    <TextBlock Text="Время" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding EstimatedTimeLabel}" Foreground="White" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#0D0912" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                                                <StackPanel>
                                                    <TextBlock Text="Уровень" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding ComplexityLabel}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <Button Content="Посмотреть детали"
                                                Height="44"
                                                Command="{Binding DataContext.OpenPreviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                    <Setter TargetName="HeartIcon" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
