<Window x:Class="TatooShop.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        Title="Регистрация в Ink&amp;Skin" Icon="/image/logo.ico" Height="720" Width="960" MinHeight="720" MinWidth="960" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:RegistrationViewModel/>
    </Window.DataContext>
    <Grid Background="{StaticResource CanvasBrush}">
        <Border Background="{StaticResource PanelBrush}" Margin="100 35" CornerRadius="12" Padding="40" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="420">
                    <TextBlock Text="Создать аккаунт" FontSize="32" FontWeight="Bold" Margin="0 0 0 10"/>
                    <TextBlock Text="Заполните данные для регистрации" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 24"/>

                    <TextBlock Text="Фамилия" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Имя" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Отчество" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Логин" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Электронная почта" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding EMail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Телефон" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Адрес" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CustomTextBoxStyle}" Margin="0 0 0 12"/>

                    <TextBlock Text="Пароль" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 5"/>
                    <PasswordBox x:Name="PasswordInput"
                                 Style="{StaticResource CustomPasswordBoxStyle}"
                                 Margin="0 0 0 12"/>

                    <Button Content="Зарегистрироваться" Height="48" Margin="0 12 0 0" Command="{Binding RegistrationCommand}" CommandParameter="{Binding ElementName=PasswordInput}"/>

                    <Button Content="Назад" Background="Transparent" Foreground="{StaticResource MutedBrush}" Margin="0 10 0 0" Click="Back_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
