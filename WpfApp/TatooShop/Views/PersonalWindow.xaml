<Window x:Class="TatooShop.Views.PersonalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TatooShop.ViewModels"
        xmlns:cmd="clr-namespace:TatooShop.Infrastructure"
        Title="Профиль — Ink&amp;Skin" Icon="/image/logo.ico" Height="780" Width="1080" MinHeight="780" MinWidth="1080" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:PersonalViewModel/>
    </Window.DataContext>
    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Шапка кабинета -->
        <Border Grid.Row="0" Margin="24 24 24 0" Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="25 20" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Личный кабинет" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="{Binding User.Login, StringFormat='Добро пожаловать, {0}'}" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
                <Button Content="Выйти из аккаунта" Width="200" Background="Transparent" BorderBrush="#FF4D4D" BorderThickness="1" 
                        Foreground="#FF4D4D" HorizontalAlignment="Right" Click="Logout_Click"/>
            </DockPanel>
        </Border>
        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="24" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                    <Setter Property="Padding" Value="20 10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="border" BorderThickness="0 0 0 2" BorderBrush="Transparent" Margin="0 0 10 0">
                                    <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Данные профиля">
                <Grid Margin="0 20">
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="30" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,-10">
                        <StackPanel Width="620" HorizontalAlignment="Left" Margin="0,0,0,-6">
                            <TextBlock Text="Личная информация" FontSize="20" FontWeight="Bold" Margin="0 0 0 20"/>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Фамилия:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.Surname}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Имя:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.Name}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Отчество:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.MiddleName}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Логин:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.Login}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Почта:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.EMail}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Телефон:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.Phone}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Адрес:" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding User.Address}" TextWrapping="Wrap"/>
                            </Grid>
                            <Separator Background="{StaticResource LineBrush}" Margin="0 20"/>
                            <Button Content="Удалить мой профиль" Command="{StaticResource DeleteCurrentUserCommand}" 
                                    Background="#33FF4D4D" Foreground="#FF4D4D" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Мои записи">
                <ListBox ItemsSource="{Binding UserReservation}" Background="Transparent" BorderThickness="0" Margin="0 20"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0 0 0 10"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush}" Padding="18" CornerRadius="12" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Master.FullName}" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Отменить" Command="{StaticResource DeleteReservationCommand}" 
                                            CommandParameter="{Binding}" IsEnabled="{Binding CanCancel}" 
                                            Width="150" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Избранное">
                <Grid Margin="0 20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}"
                            CornerRadius="12"
                            Padding="22"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            Margin="0 0 0 18">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="Избранные эскизы" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="Сохраненные работы из каталога" Foreground="{StaticResource MutedBrush}" Margin="0 5 0 0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UserFavorite.Count, StringFormat={}{0} в избранном}"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding UserFavorite}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="250"
                                        Margin="0 0 18 18"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="220"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Image Source="{Binding Sketch.ImageSource}" Stretch="UniformToFill"/>
                                        <Button Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="12"
                                                Width="36"
                                                Height="36"
                                                Background="#E6110B18"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="Х" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="18" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Border Grid.Row="1" Padding="15" Background="#F2110B18">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Sketch.StyleLabel}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Sketch.AuthorName}" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="Техподдержка">
                <ScrollViewer Margin="0 20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            Margin="0 0 18 0">
                        <StackPanel>
                            <TextBlock Text="Новое обращение" FontSize="20" FontWeight="Bold" Margin="0 0 0 18"/>
                            <TextBlock Text="Тема" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 6"/>
                            <TextBox Text="{Binding SupportSubject, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     Margin="0 0 0 14"/>

                            <TextBlock Text="Сообщение" Foreground="{StaticResource MutedBrush}" Margin="0 0 0 6"/>
                            <TextBox Text="{Binding SupportMessage, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CustomTextBoxStyle}"
                                     Height="150"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Margin="0 0 0 18"/>

                            <Button Content="Отправить"
                                    Command="{Binding SendSupportRequestCommand}"
                                    MinWidth="150"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Мои обращения" FontSize="20" FontWeight="Bold" Margin="0 0 0 18"/>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding UserSupportRequests}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0D0912"
                                                Margin="0 0 0 12"
                                                Padding="16"
                                                CornerRadius="10"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <DockPanel Margin="0 0 0 8">
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                    <TextBlock Text="{Binding Subject}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               TextWrapping="Wrap"/>
                                                </DockPanel>

                                                <TextBlock Text="{Binding Message}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource InkBrush}"
                                                           Margin="0 0 0 12"/>

                                                <Border Background="#160F1F"
                                                        CornerRadius="8"
                                                        Padding="12"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Ответ администратора"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0 0 0 6"/>
                                                        <TextBlock Text="{Binding AdminReply}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource MutedBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsProcessed}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="Ожидает ответа"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsProcessed}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
